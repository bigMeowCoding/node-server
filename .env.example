PORT=3000
NODE_ENV=development

JWT_SECRET=your-secret-key-here-change-it-in-production
JWT_EXPIRES_IN=7d

# 使用 SQLite（默认，无需配置即可运行）
DB_DIALECT=sqlite

# 如需使用 MySQL，请取消下面注释并配置密码
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=你的密码
# DB_DATABASE=shop_db

CORS_ORIGIN=http://localhost:5173
